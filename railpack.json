{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.26.1 --activate",
        "pnpm install --no-frozen-lockfile"
      ]
    },
    "build": {
      "dependsOn": ["install"],
      "commands": [
        "pnpm -r --if-present run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/api-server run start"
  }
}
