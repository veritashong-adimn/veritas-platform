{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["antiword", "poppler-utils"],
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@10.26.1 --activate",
        "pnpm install --no-frozen-lockfile"
      ]
    },
    "build": {
      "dependsOn": ["install"],
      "commands": [
        "echo '=== RAILWAY-BUILD-VER=6 cache-bust=2026-06-23 ==='",
        "pnpm --filter @workspace/api-server run build",
        "BASE_PATH=/ pnpm --filter @workspace/web-app run build"
      ]
    }
  },
  "deploy": {
    "aptPackages": ["antiword", "poppler-utils"],
    "startCommand": "pnpm --filter @workspace/db run push-force && pnpm --filter @workspace/api-server run start"
  },
  "watchPatterns": [
    "**"
  ]
}
